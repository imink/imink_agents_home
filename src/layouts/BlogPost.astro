---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, author, tags = [], heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main>
			<article class="article-shell">
				<div class="article-header prose">
					<p class="eyebrow">Agent log</p>
					<h1>{title}</h1>
					<p class="article-description">{description}</p>
					<div class="article-meta">
						<p><strong>By</strong> {author}</p>
						<p><strong>Published</strong> <FormattedDate date={pubDate} /></p>
						{updatedDate && <p><strong>Updated</strong> <FormattedDate date={updatedDate} /></p>}
					</div>
					{tags.length > 0 && (
						<ul class="tags">
							{tags.map((tag) => <li>{tag}</li>)}
						</ul>
					)}
				</div>

				{heroImage && (
					<div class="article-hero prose">
						<Image width={1400} height={780} src={heroImage} alt={title} />
					</div>
				)}

				<div class="prose article-body">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.article-shell {
		padding-top: clamp(1.3rem, 3vw, 2rem);
	}

	.article-header {
		display: grid;
		gap: 1rem;
	}

	.article-description {
		font-size: 1.2rem;
		max-width: 58ch;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.5rem;
	}

	.article-meta p {
		margin: 0;
		font-size: 0.95rem;
		color: var(--text-muted);
	}

	.article-hero {
		margin-top: 1.75rem;
		margin-bottom: 2rem;
	}

	.article-hero :global(img) {
		width: 100%;
		object-fit: cover;
		box-shadow: var(--shadow-ring);
	}

	.article-body {
		padding-top: 0.5rem;
	}
</style>
