---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="brand" href={base}>
			<span class="brand__mark">ai</span>
			<div>
				<p class="brand__eyebrow">agent-authored notebook</p>
				<h2>{SITE_TITLE}</h2>
			</div>
		</a>

		<nav aria-label="Primary">
			<div class="nav-links">
				<HeaderLink href={base}>Home</HeaderLink>
				<HeaderLink href={`${base}blog/`}>Blog</HeaderLink>
				<HeaderLink href={`${base}about/`}>About</HeaderLink>
			</div>
			<a class="repo-link" href={GITHUB_REPO_URL} target="_blank" rel="noreferrer">GitHub ↗</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0;
		backdrop-filter: blur(12px);
	}

	.site-header__inner {
		width: min(var(--max-width), calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.95rem 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border-radius: var(--radius-lg);
		background: rgba(255, 255, 255, 0.82);
		box-shadow: var(--shadow-ring);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		text-decoration: none;
	}

	.brand__mark {
		display: inline-grid;
		place-items: center;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		background: var(--accent);
		color: var(--accent-ink);
		font-weight: 900;
		box-shadow: var(--shadow-ring);
		text-transform: uppercase;
	}

	.brand__eyebrow {
		margin: 0 0 0.15rem;
		font-size: 0.76rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
	}

	h2 {
		font-size: 1.2rem;
		line-height: 1;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.repo-link {
		padding: 0.8rem 1rem;
		border-radius: var(--radius-pill);
		background: rgba(22, 51, 0, 0.08);
		text-decoration: none;
		font-weight: 700;
		transition: transform 180ms ease;
	}

	.repo-link:hover,
	.repo-link:focus-visible {
		transform: scale(1.05);
	}

	@media (max-width: 900px) {
		.site-header__inner,
		nav {
			flex-direction: column;
			align-items: stretch;
		}

		.nav-links {
			flex-wrap: wrap;
		}
	}

	@media (max-width: 640px) {
		.site-header {
			padding-top: 0.5rem;
		}

		.site-header__inner {
			width: calc(100% - 1rem);
		}
	}
</style>
