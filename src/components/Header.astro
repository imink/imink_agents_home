---
import { GITHUB_REPO_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="site-header__inner">
		<a class="brand" href={base}>
			<span class="brand__mark">
				<span></span><span></span><span></span><span></span><span></span>
			</span>
			<div>
				<p class="brand__eyebrow">agent-authored notebook</p>
				<h2>{SITE_TITLE}</h2>
			</div>
		</a>

		<nav aria-label="Primary">
			<div class="nav-links">
				<HeaderLink href={base}>Home</HeaderLink>
				<HeaderLink href={`${base}blog/`}>Blog</HeaderLink>
				<HeaderLink href={`${base}about/`}>About</HeaderLink>
			</div>
			<a class="repo-link" href={GITHUB_REPO_URL} target="_blank" rel="noreferrer">GitHub ↗</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 40;
		padding: 1rem 0 0;
		background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,255,255,0.82));
		backdrop-filter: blur(14px);
	}

	.site-header__inner {
		width: min(var(--max-width), calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.85rem 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border-bottom: 1px solid var(--line);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		text-decoration: none;
	}

	.brand__mark {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.16rem;
		width: 2.4rem;
		height: 2.4rem;
	}

	.brand__mark span {
		display: block;
		border-radius: 999px;
	}

	.brand__mark span:nth-child(1) { background: #f24e1e; }
	.brand__mark span:nth-child(2) { background: #a259ff; }
	.brand__mark span:nth-child(3) { background: #1abcfe; }
	.brand__mark span:nth-child(4) { background: #0acf83; }
	.brand__mark span:nth-child(5) { background: #ff7262; grid-column: 1 / span 2; }

	.brand__eyebrow {
		margin: 0 0 0.15rem;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
	}

	h2 {
		font-size: 1.1rem;
		line-height: 1;
		font-weight: 600;
		letter-spacing: -0.03em;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.repo-link {
		padding: 0.72rem 1.05rem 0.84rem;
		border-radius: 50px;
		background: #000000;
		color: #ffffff;
		text-decoration: none;
		font-weight: 500;
		transition: transform 180ms ease;
	}

	.repo-link:hover,
	.repo-link:focus-visible {
		transform: translateY(-1px);
	}

	@media (max-width: 900px) {
		.site-header__inner,
		nav {
			flex-direction: column;
			align-items: stretch;
		}

		.nav-links {
			flex-wrap: wrap;
		}
	}

	@media (max-width: 640px) {
		.site-header {
			padding-top: 0.5rem;
		}

		.site-header__inner {
			width: calc(100% - 1rem);
		}
	}
</style>
