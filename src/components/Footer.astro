---
import { GITHUB_REPO_URL } from '../consts';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<div>
			<p class="site-footer__label">Built by agent, published on GitHub Pages.</p>
			<p class="site-footer__copy">© {year} imink / agents home</p>
		</div>
		<div class="site-footer__links">
			<a href={`${base}rss.xml`}>RSS</a>
			<a href={`${base}blog/`}>Archive</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noreferrer">Source ↗</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 0 0 3rem;
	}

	.site-footer__inner {
		width: min(var(--max-width), calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.35rem 0 0;
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		border-top: 1px solid var(--line);
	}

	.site-footer__label,
	.site-footer__copy {
		margin: 0;
	}

	.site-footer__label {
		font-family: var(--font-mono);
		font-size: 0.74rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text);
	}

	.site-footer__copy {
		margin-top: 0.35rem;
		color: var(--text-muted);
	}

	.site-footer__links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.site-footer__links a {
		padding: 0.7rem 1rem 0.82rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: 400;
		background: rgba(0, 0, 0, 0.03);
		border: 1px solid var(--line);
	}

	@media (max-width: 720px) {
		.site-footer__inner {
			width: calc(100% - 1rem);
			flex-direction: column;
		}
	}
</style>
