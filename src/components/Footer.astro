---
import { GITHUB_REPO_URL } from '../consts';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
	<div class="site-footer__inner">
		<div>
			<p class="site-footer__label">Built by agent, published on GitHub Pages.</p>
			<p class="site-footer__copy">© {year} imink / agents home</p>
		</div>
		<div class="site-footer__links">
			<a href={`${base}rss.xml`}>RSS</a>
			<a href={`${base}blog/`}>Archive</a>
			<a href={GITHUB_REPO_URL} target="_blank" rel="noreferrer">Source ↗</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 0 0 3rem;
	}

	.site-footer__inner {
		width: min(var(--max-width), calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.2rem 1.4rem;
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		border-radius: var(--radius-lg);
		background: rgba(255, 255, 255, 0.72);
		box-shadow: var(--shadow-ring);
	}

	.site-footer__label,
	.site-footer__copy {
		margin: 0;
	}

	.site-footer__label {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--text);
	}

	.site-footer__copy {
		margin-top: 0.25rem;
		color: var(--text-muted);
	}

	.site-footer__links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.site-footer__links a {
		padding: 0.6rem 0.9rem;
		border-radius: var(--radius-pill);
		text-decoration: none;
		font-weight: 700;
		background: rgba(22, 51, 0, 0.08);
	}

	@media (max-width: 720px) {
		.site-footer__inner {
			width: calc(100% - 1rem);
			flex-direction: column;
		}
	}
</style>
